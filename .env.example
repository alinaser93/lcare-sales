# انسخ هذا الملف إلى .env (للتجربة المحلية فقط) وضع قيمك.
# في Netlify: أضِف نفس المتغيرات من Site settings → Environment variables.

# مفتاح الذكاء الاصطناعي (مطلوب لميزات الاستخراج)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# التخزين السحابي / المزامنة بين الأجهزة (اختياري — Supabase)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key
